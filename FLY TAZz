--- LOGIC XỬ LÝ ---

local speeds = 1
local nowe = false
local speaker = game.Players.LocalPlayer
local tpwalking = false

-- Thông báo
game:GetService("StarterGui"):SetCore("SendNotification", { 
    Title = "TrongNguyen Fly";
    Text = "UI Modern Loaded!";
    Duration = 5;
})

-- Hàm Fly chính
onof.MouseButton1Click:Connect(function()
    nowe = not nowe
    if nowe then
        onof.Text = "FLY: ON"
        onof.BackgroundColor3 = Color3.fromRGB(50, 200, 50)
        
        -- Bật chế độ bay (logic tối ưu hơn)
        task.spawn(function()
            local char = speaker.Character
            if not char then return end
            local hum = char:FindFirstChildOfClass("Humanoid")
            local root = char:FindFirstChild("HumanoidRootPart")
            
            for _, state in pairs(Enum.HumanoidStateType:GetEnumItems()) do
                hum:SetStateEnabled(state, false)
            end
            hum:ChangeState(Enum.HumanoidStateType.Swimming)
            
            while nowe and char and root do
                local hb = game:GetService("RunService").Heartbeat:Wait()
                if hum.MoveDirection.Magnitude > 0 then
                    root.CFrame = root.CFrame + (hum.MoveDirection * speeds * 0.5)
                end
            end
            
            -- Reset khi tắt
            for _, state in pairs(Enum.HumanoidStateType:GetEnumItems()) do
                hum:SetStateEnabled(state, true)
            end
            hum:ChangeState(Enum.HumanoidStateType.GettingUp)
        end)
    else
        onof.Text = "FLY: OFF"
        onof.BackgroundColor3 = Color3.fromRGB(120, 80, 200)
    end
end)

-- Tăng/Giảm tốc độ
plus.MouseButton1Click:Connect(function()
    speeds = speeds + 1
    speed.Text = tostring(speeds)
end)

mine.MouseButton1Click:Connect(function()
    if speeds > 1 then
        speeds = speeds - 1
        speed.Text = tostring(speeds)
    end
end)

-- Nút Lên/Xuống (Giữ để di chuyển)
local flyingUp = false
local flyingDown = false

up.MouseButton1Down:Connect(function() flyingUp = true end)
up.MouseButton1Up:Connect(function() flyingUp = false end)
down.MouseButton1Down:Connect(function() flyingDown = true end)
down.MouseButton1Up:Connect(function() flyingDown = false end)

game:GetService("RunService").RenderStepped:Connect(function()
    if nowe and speaker.Character and speaker.Character:FindFirstChild("HumanoidRootPart") then
        if flyingUp then
            speaker.Character.HumanoidRootPart.CFrame *= CFrame.new(0, 1 * (speeds/2), 0)
        end
        if flyingDown then
            speaker.Character.HumanoidRootPart.CFrame *= CFrame.new(0, -1 * (speeds/2), 0)
        end
    end
end)

